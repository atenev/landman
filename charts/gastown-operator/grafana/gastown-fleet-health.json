      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(dgt_fleet_convergence_score == 1) OR vector(0)",
          "legendFormat": "Converged",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(dgt_fleet_convergence_score >= 0) OR vector(1)",
          "legendFormat": "Total",
          "refId": "B"
        }
      ],
      "title": "Converged Rigs",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
